# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — it never gets committed.
#
# Used for LOCAL playwright runs only. CI uses GitHub Environment secrets
# (set in repo Settings → Environments → dev / stage / qa / prod).

# Test user credentials. Use a sandbox account, never a real production user.
XT_USER_EMAIL=
XT_USER_PASSWORD=

# Optional: TOTP seed for MFA tests (Base32). Leave blank if MFA isn't enabled.
XT_TOTP_SECRET=

# Default environment (overridden when you run with XT_ENV=stage etc.).
# One of: local, dev, stage, qa, prod.
XT_ENV=dev

# Optional override flags
# XT_RUN_DESTRUCTIVE=1   # opt in to TC-PF-006 (changes the live password)
