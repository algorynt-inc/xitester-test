{
    "name": "xitester-playwright",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "description": "Playwright suite for XiTester manual test cases under test-cases/. Mirrors test-cases/login.md.",
    "scripts": {
        "test": "playwright test",
        "test:local": "cross-env XT_ENV=local playwright test",
        "test:pre-dev": "cross-env XT_ENV=pre-dev playwright test",
        "test:dev": "cross-env XT_ENV=dev playwright test",
        "test:stage": "cross-env XT_ENV=stage playwright test",
        "test:qa": "cross-env XT_ENV=qa playwright test",
        "test:headed": "playwright test --headed",
        "test:ui": "playwright test --ui",
        "test:ui:local": "cross-env XT_ENV=local playwright test --ui",
        "test:ui:pre-dev": "cross-env XT_ENV=pre-dev playwright test --ui",
        "test:ui:dev": "cross-env XT_ENV=dev playwright test --ui",
        "test:ui:stage": "cross-env XT_ENV=stage playwright test --ui",
        "test:ui:qa": "cross-env XT_ENV=qa playwright test --ui",
        "test:login": "playwright test tests/login.spec.ts",
        "report": "playwright show-report",
        "install-browsers": "playwright install chromium"
    },
    "dependencies": {
        "dotenv": "^16.4.7"
    },
    "devDependencies": {
        "@playwright/test": "^1.50.0",
        "@types/node": "^22.0.0",
        "cross-env": "^7.0.3",
        "typescript": "^5.5.0"
    }
}
