# Copy to .env.local for local dev. None of these are required for build,
# but the dashboard won't be functional until they match the deployed repo.

VITE_REPO_OWNER=algorynt-inc
VITE_REPO_NAME=xitester-test
VITE_REQUIRED_ORG=algorynt-inc

# OAuth App Client ID for GitHub Device Flow login.
# If unset, only the PAT-paste login is offered.
VITE_GITHUB_CLIENT_ID=
